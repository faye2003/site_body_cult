rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: services
    // - name: string (required)
    // - description: string (required)
    // - imageUrl: string
    // - category: string (required)
    //
    // Collection: pricing
    // - name: string (required)
    // - price: number (required)
    // - category: string (required)
    //
    // Collection: gallery
    // - imageUrl: string (required)
    // - title: string
    // - category: string (required)
    //
    // Collection: settings
    // - name: string
    // - phone: string
    // - whatsapp: string
    // - address: string
    // - email: string
    // - hours: map
    // - description: string
    //
    // Collection: users
    // - role: string (admin/user)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "fayem7409@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    function isValidNumber(field) {
      return request.resource.data[field] is number;
    }

    // Rules
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pricing/{priceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
